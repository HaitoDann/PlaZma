rules_version = '2';

// ============================================================
//  ARCHI — Règles de sécurité Firestore (PlaZma Esport)
//  Ce fichier est la SEULE protection réelle des données.
//  À déployer dans la console Firebase (Firestore → Règles) ou via la CLI.
//
//  Auth : connexion par NOM D'UTILISATEUR (style GLPI). En interne, le pseudo
//  devient "<pseudo>@archi.local" côté Firebase Auth (aucun e-mail réel).
//  Modèle : chaque utilisateur a un document users/{uid} :
//    { name, username, role: 'admin'|'staff', disabled: false,
//      sections: { planning, scrim, scouting, team, dashboard, coach,
//                  satisfaction, satisfactionResults, perf } }
//  Chaque section vaut 'edit' (voir + modifier), 'view' (voir seulement),
//  true (ancien modèle = 'edit'), ou est absente (aucun accès).
//  - role 'admin' : accès total + gestion des comptes.
// ============================================================
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function profile()  { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function hasProfile() {
      return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    function active()  { return hasProfile() && profile().disabled != true; }
    function isAdmin() { return active() && profile().role == 'admin'; }
    // Niveau d'accès à une section (null si aucun) ; tolère l'absence du champ.
    function lvl(section) {
      return active() && ('sections' in profile()) ? profile().sections.get(section, null) : null;
    }
    // Lecture : admin, ou section en 'view'/'edit'/true.  Écriture : admin, ou 'edit'/true.
    function canRead(section)  { return active() && (profile().role == 'admin' || lvl(section) == true || lvl(section) == 'edit' || lvl(section) == 'view'); }
    function canWrite(section) { return active() && (profile().role == 'admin' || lvl(section) == true || lvl(section) == 'edit'); }

    // ---- Comptes utilisateurs ----
    match /users/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow write: if isAdmin();
    }

    // ---- Collection principale (plazma) : accès par document ----
    match /plazma/{docId} {
      allow read: if docId == 'roster'
        || (signedIn() && (
              docId == 'config'
           || (docId == 'team-identity'    && canRead('team'))
           || (docId == 'dashboard'        && canRead('dashboard'))
           || (docId == 'coach-evaluation' && canRead('coach'))
           || (docId.matches('schedule-.*') && canRead('planning'))
           || (docId.matches('perf-.*')     && canRead('perf'))
        ));
      allow write: if signedIn() && (
              (docId == 'config'           && isAdmin())
           || (docId == 'roster'           && canWrite('team'))
           || (docId == 'team-identity'    && canWrite('team'))
           || (docId == 'dashboard'        && canWrite('dashboard'))
           || (docId == 'coach-evaluation' && canWrite('coach'))
           || (docId.matches('schedule-.*') && canWrite('planning'))
           || (docId.matches('perf-.*')     && canWrite('perf'))
      );
    }

    // ---- Scrim ----
    match /plazma-scrims/{id} {
      allow read:  if canRead('scrim');
      allow write: if canWrite('scrim');
    }

    // ---- Scouting ----
    match /plazma-scouting/{id} {
      allow read:  if canRead('scouting');
      allow write: if canWrite('scouting');
    }

    // ---- Satisfaction (joueurs) ----
    // Soumission publique ; lecture réservée aux « résultats », suppression = 'edit'.
    match /plazma-satisfaction/{id} {
      allow create: if true;
      allow read:   if canRead('satisfactionResults');
      allow delete: if canWrite('satisfactionResults');
      allow update: if false;
    }

    // ---- Satisfaction Head Coach ----
    match /plazma-satisfaction-coach/{id} {
      allow create: if true;
      allow read:   if canRead('satisfactionResults');
      allow delete: if canWrite('satisfactionResults');
      allow update: if false;
    }

    // Tout le reste est refusé par défaut.
  }
}
